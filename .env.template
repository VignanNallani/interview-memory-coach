# ─── LLM provider (OpenAI-compatible) ────────────────────────────────────────
# Cognee uses this for entity extraction during cognify().
# Switch between Groq and Mistral by changing the three vars below.

# --- Groq ---
# LLM_PROVIDER must be "openai" — that's the only OpenAI-compat adapter cognee exposes.
# Use the groq/ prefix on the model so litellm routes natively to Groq (no custom endpoint needed).
LLM_PROVIDER=openai
LLM_API_KEY=gsk_YOUR_GROQ_KEY_HERE
LLM_MODEL=groq/llama-3.1-8b-instant
# LLM_ENDPOINT intentionally omitted — litellm knows Groq's URL from the groq/ model prefix

# --- Mistral (comment out Groq block and uncomment this) ---
# LLM_PROVIDER=openai
# LLM_API_KEY=YOUR_MISTRAL_KEY_HERE
# LLM_MODEL=mistral-small-latest
# LLM_ENDPOINT=https://api.mistral.ai/v1

# Embedding model — used by cognee to vectorise chunks before storing in LanceDB.
# Groq doesn't serve embeddings; use a free OpenAI-compatible provider or local model.
# Option A: OpenAI (paid)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small

# Option B (active): local fastembed — free, no API key, runs on CPU.
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ─── cognee 1.x access control ───────────────────────────────────────────────
# cognee 1.0+ enables multi-tenant auth by default.  Set false for local single-user use.
ENABLE_BACKEND_ACCESS_CONTROL=false

# ─── Local storage paths (no cloud, no API keys needed) ───────────────────────

# LanceDB: columnar vector store written to disk; cognee embeds and queries chunks here.
VECTOR_DB_PROVIDER=lancedb
VECTOR_DB_URL=./data/lancedb

# KuzuDB: embedded C++ property graph DB; cognee writes entity/relationship triples here.
GRAPH_DATABASE_PROVIDER=ladybug   # cognee 1.x uses ladybug (a KuzuDB wrapper), not raw kuzu
GRAPH_DATABASE_URL=./data/kuzu

# SQLite: relational bookkeeping (dataset registry, document metadata, task status).
DB_PROVIDER=sqlite
DB_PATH=./data
DB_NAME=cognee_db
